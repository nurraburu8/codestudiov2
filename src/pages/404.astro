---
import Layout from '@layouts/Layout.astro';
import Footer from '@components/Footer.astro';
---

<Layout
  title="404 — Página no encontrada · Code Studio"
  description="La página que estás buscando no existe."
  noindex={true}
>
  <main class="nf">
    <div class="nf-inner">
      <span class="nf-tag">Error 404</span>
      <h1 class="nf-title">No se pudo<br />encontrar la página.</h1>
      <p class="nf-msg">
        Capaz se mudó, capaz nunca existió. Volvé al inicio para seguir navegando.
      </p>
      <a href="/" class="btn-cta">
        Volver al inicio
        <span class="arrow">→</span>
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .nf {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 5vw 80px;
    background: var(--bg);
  }

  .nf-inner {
    max-width: 720px;
    text-align: center;
  }

  .nf-tag {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    margin-bottom: 28px;
  }

  .nf-tag::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  .nf-title {
    font-family: var(--ff-display);
    font-size: clamp(48px, 8vw, 108px);
    line-height: 0.92;
    color: var(--milk);
    margin-bottom: 28px;
  }

  .nf-msg {
    font-size: clamp(15px, 1.2vw, 18px);
    color: var(--milk);
    opacity: 0.7;
    margin-bottom: 48px;
    line-height: 1.6;
  }
</style>
