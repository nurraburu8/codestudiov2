---
/**
 * Página dinámica de detalle por trabajo.
 * Genera 1 HTML estático por cada trabajo de la colección.
 * URL: /work/<slug>/
 */
import { render } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Gallery from '@components/Gallery.astro';
import { getAllTrabajos, resolveVideo } from '@lib/trabajos';
import { SITE } from '@/consts';

const base = (Astro.site ?? new URL(SITE.url)).origin;

export async function getStaticPaths() {
  const trabajos = await getAllTrabajos();
  return trabajos.map((w) => ({
    params: { id: w.id },
    props: { work: w },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const video = resolveVideo(work.data);

const pageTitle = `${work.data.client} — Code Studio`;
// Description rica: tagline + tipo + cliente + año + ubicación.
// Sale entre 130-160 chars, mejor SEO que el tagline solo.
const pageDescription = [
  work.data.tagline,
  `${work.data.type.toLowerCase()} para ${work.data.client} (${work.data.year}).`,
  `Producción Code Studio en ${work.data.location}.`,
]
  .filter(Boolean)
  .join(' ')
  .slice(0, 160);

const categorySlug = work.data.category === 'Campañas' ? 'campanas' : 'shows';

const videoJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: `${work.data.client} — ${work.data.type}`,
  description: work.body ?? '',
  thumbnailUrl: video.poster.startsWith('http') ? video.poster : `${base}${video.poster}`,
  uploadDate: `${work.data.year}-01-01`,
  contentUrl: video.src.startsWith('http') ? video.src : `${base}${work.data.video}`,
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: `${base}/logo.png`,
  },
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  jsonLd={videoJsonLd}
>
  <Header />

  <div class="back-bar">
    <a href={`/${categorySlug}`}>← Volver a {work.data.category}</a>
  </div>

  <section class="work-hero">
    <div class="work-meta">
      <span class="work-cat">{work.data.category}</span>
      <span class="work-year">{work.data.year}</span>
      <span class="work-loc">{work.data.location}</span>
    </div>
    <h1 class="work-title">
      <span class="type">{work.data.type}</span>
      <span class="client">{work.data.client}</span>
    </h1>
    {work.data.tagline && <p class="work-tagline">"{work.data.tagline}"</p>}
    <div class="video-wrap">
      <video controls preload="metadata" playsinline poster={video.poster}>
        <source src={video.src} type="video/mp4" />
      </video>
    </div>
  </section>

  <section class="work-body">
    <div class="work-desc">
      <Content />
    </div>

    <aside class="sidebar">
      {
        work.data.stats.length > 0 && (
          <div class="stats">
            {work.data.stats.map((s) => (
              <div class="stat-card">
                <div class="v">{s.value}</div>
                <div class="k">{s.label}</div>
              </div>
            ))}
          </div>
        )
      }

      {
        work.data.credits.length > 0 && (
          <div class="credits">
            <h4>Créditos</h4>
            <div class="credits-list">
              {work.data.credits.map((c) => (
                <div class="credit-row">
                  <span class="k">{c.role}</span>
                  <span class="v">{c.name}</span>
                </div>
              ))}
            </div>
          </div>
        )
      }
    </aside>
  </section>

  <section class="related">
    <h2>Otros trabajos</h2>
    <Gallery filter="all" limit={3} />
  </section>

  <Footer />
</Layout>

<style>
  .back-bar {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: 100px 5vw 0;
  }

  .back-bar a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk; el hover sí vuelve naranja */
    color: var(--black);
    transition: gap 0.3s, color 0.3s;
  }

  .back-bar a:hover { color: var(--light); }

  .back-bar a:hover { gap: 14px; }

  .work-hero {
    position: relative;
    z-index: 1;
    padding: 60px 5vw 0;
    max-width: 1480px;
    margin: 0 auto;
  }

  .work-meta {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .work-cat {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk */
    color: var(--black);
    font-weight: 500;
  }

  .work-year {
    font-size: 11px;
    color: var(--black);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .work-loc {
    font-size: 11px;
    color: var(--black);
    opacity: 0.55;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .work-title {
    font-family: var(--ff-display);
    font-size: clamp(48px, 9vw, 132px);
    line-height: 0.88;
    letter-spacing: 0.01em;
    margin-bottom: 6px;
    color: var(--black);
  }

  .work-title .type {
    display: block;
    font-family: var(--ff-body);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(12px, 1.1vw, 16px);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    /* Negro con opacidad para contraste WCAG */
    color: var(--black);
    opacity: 0.6;
    margin-bottom: 18px;
  }

  .work-title .client { display: block; }

  .work-tagline {
    font-style: italic;
    font-weight: 300;
    font-size: clamp(16px, 1.6vw, 22px);
    color: rgba(0, 0, 0, 0.55);
    max-width: 760px;
    margin: 18px 0 48px;
    line-height: 1.4;
  }

  .video-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--black);
    border: 1px solid rgba(0, 0, 0, 0.15);
  }

  .video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work-body {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: 80px 5vw 40px;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(40px, 6vw, 100px);
  }

  .work-desc :global(p) {
    font-size: clamp(16px, 1.25vw, 19px);
    line-height: 1.65;
    color: var(--black);
    opacity: 0.78;
    letter-spacing: 0.005em;
    margin-bottom: 22px;
  }

  .work-desc :global(p:first-of-type::first-line) {
    font-weight: 600;
    /* Negro bold (contraste WCAG) en lugar de naranja chico */
    color: var(--black);
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .sidebar h4 {
    font-family: var(--ff-body);
    display: inline-block;
    align-self: flex-start;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk */
    color: var(--black);
    font-weight: 500;
    margin-bottom: 18px;
  }

  .credit-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid var(--hair);
    gap: 16px;
  }

  .credit-row .k {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk */
    color: var(--black);
    font-weight: 600;
  }

  .credit-row .v {
    font-size: 13px;
    color: var(--black);
    text-align: right;
    font-weight: 500;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .stat-card {
    padding: 22px 14px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    text-align: center;
    background: transparent;
  }

  .stat-card .v {
    font-family: var(--ff-display);
    font-size: clamp(28px, 3vw, 40px);
    color: var(--light);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-card .k {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--black);
    opacity: 0.55;
    font-weight: 500;
  }

  .related {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 60px auto 0;
    padding: 0 5vw 100px;
  }

  .related h2 {
    font-family: var(--ff-display);
    font-size: clamp(28px, 3.6vw, 48px);
    letter-spacing: 0.01em;
    margin-bottom: 36px;
    color: var(--black);
  }

  .related :global(.card-grid) { padding: 0; }

  @media (max-width: 820px) {
    .work-hero { padding-top: 30px; }
    .work-body {
      grid-template-columns: 1fr;
      padding-top: 50px;
      gap: 50px;
    }
    .stat-card { padding: 14px 8px; }
  }
</style>
