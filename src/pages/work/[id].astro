---
/**
 * Página dinámica de detalle por trabajo.
 * Genera una HTML estática por cada work en build time (mejor SEO que ?id=).
 * URL final: /work/<id>/
 */
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Gallery from '@components/Gallery.astro';
import { WORKS } from '@/data/works';
import { SITE } from '@/consts';

export function getStaticPaths() {
  return WORKS.map((w) => ({
    params: { id: w.id },
    props: { work: w },
  }));
}

const { work } = Astro.props;
const otherWorks = WORKS.filter((w) => w.id !== work.id).slice(0, 3);

const pageTitle = `${work.client} — Code Studio`;
const pageDescription = work.tagline || `${work.type} — ${work.client} por Code Studio.`;

// VideoObject JSON-LD para que Google indexe el video como rich result
const videoJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: `${work.client} — ${work.type}`,
  description: work.description.join(' '),
  thumbnailUrl: `${SITE.url}/hero-poster.jpg`,
  uploadDate: `${work.year}-01-01`,
  contentUrl: `${SITE.url}${work.video}`,
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: `${SITE.url}/logo.png`,
  },
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  jsonLd={videoJsonLd}
>
  <Header />

  <div class="back-bar">
    <a href={`/${work.category === 'Marcas' ? 'marcas' : work.category === 'Eventos' ? 'eventos' : 'shows'}`}>
      ← Volver a {work.category}
    </a>
  </div>

  <section class="work-hero">
    <div class="work-meta">
      <span class="work-cat">{work.category}</span>
      <span class="work-year">{work.year}</span>
      <span class="work-loc">{work.location}</span>
    </div>
    <h1 class="work-title">
      <span class="type">{work.type}</span>
      <span class="client">{work.client}</span>
    </h1>
    {work.tagline && <p class="work-tagline">"{work.tagline}"</p>}
    <div class="video-wrap">
      <video controls preload="metadata" playsinline poster="/hero-poster.jpg">
        <source src={work.video} type="video/mp4" />
      </video>
    </div>
  </section>

  <section class="work-body">
    <div class="work-desc">
      {work.description.map((p) => <p>{p}</p>)}
    </div>

    <aside class="sidebar">
      <div class="stats">
        {
          work.stats.map((s) => (
            <div class="stat-card">
              <div class="v">{s.v}</div>
              <div class="k">{s.k}</div>
            </div>
          ))
        }
      </div>

      <div class="credits">
        <h4>Créditos</h4>
        <div class="credits-list">
          {
            Object.entries(work.credits).map(([k, v]) => (
              <div class="credit-row">
                <span class="k">{k}</span>
                <span class="v">{v}</span>
              </div>
            ))
          }
        </div>
      </div>
    </aside>
  </section>

  {
    otherWorks.length > 0 && (
      <section class="related">
        <h2>Otros trabajos</h2>
        <Gallery filter="all" limit={3} />
      </section>
    )
  }

  <Footer />
</Layout>

<style>
  .back-bar {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: 100px 5vw 0;
  }

  .back-bar a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--light);
    transition: gap 0.3s;
  }

  .back-bar a:hover { gap: 14px; }

  /* HERO */
  .work-hero {
    position: relative;
    z-index: 1;
    padding: 60px 5vw 0;
    max-width: 1480px;
    margin: 0 auto;
  }

  .work-meta {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .work-cat {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
  }

  .work-cat::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: currentColor;
  }

  .work-year {
    font-size: 11px;
    color: var(--milk);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .work-loc {
    font-size: 11px;
    color: var(--milk);
    opacity: 0.7;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .work-title {
    font-family: var(--ff-display);
    font-size: clamp(48px, 9vw, 132px);
    line-height: 0.88;
    letter-spacing: 0.01em;
    margin-bottom: 6px;
    color: var(--milk);
  }

  .work-title .type {
    display: block;
    font-family: var(--ff-body);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(12px, 1.1vw, 16px);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--light);
    opacity: 0.7;
    margin-bottom: 18px;
  }

  .work-title .client { display: block; }

  .work-tagline {
    font-style: italic;
    font-weight: 300;
    font-size: clamp(16px, 1.6vw, 22px);
    color: rgba(235, 235, 235, 0.55);
    max-width: 760px;
    margin: 18px 0 48px;
    line-height: 1.4;
  }

  .video-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--black);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* BODY */
  .work-body {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 0 auto;
    padding: 80px 5vw 40px;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(40px, 6vw, 100px);
  }

  .work-desc p {
    font-size: clamp(16px, 1.25vw, 19px);
    line-height: 1.65;
    color: var(--milk);
    letter-spacing: 0.005em;
    margin-bottom: 22px;
  }

  .work-desc p:first-of-type::first-line {
    font-weight: 600;
    color: var(--light);
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .sidebar h4 {
    font-family: var(--ff-body);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    align-self: flex-start;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    margin-bottom: 18px;
  }

  .sidebar h4::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: currentColor;
  }

  .credit-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid var(--hair);
    gap: 16px;
  }

  .credit-row .k {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 600;
  }

  .credit-row .v {
    font-size: 13px;
    color: var(--milk);
    text-align: right;
    font-weight: 500;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .stat-card {
    padding: 22px 14px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    text-align: center;
    background: transparent;
  }

  .stat-card .v {
    font-family: var(--ff-display);
    font-size: clamp(28px, 3vw, 40px);
    color: var(--light);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-card .k {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--milk);
    opacity: 0.55;
    font-weight: 500;
  }

  /* RELATED */
  .related {
    position: relative;
    z-index: 1;
    max-width: 1480px;
    margin: 60px auto 0;
    padding: 0 5vw 100px;
  }

  .related h2 {
    font-family: var(--ff-display);
    font-size: clamp(28px, 3.6vw, 48px);
    letter-spacing: 0.01em;
    margin-bottom: 36px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--light);
    color: var(--milk);
  }

  .related :global(.card-grid) { padding: 0; }

  @media (max-width: 820px) {
    .work-hero { padding-top: 30px; }
    .work-body {
      grid-template-columns: 1fr;
      padding-top: 50px;
      gap: 50px;
    }
    .stat-card { padding: 14px 8px; }
  }
</style>
