---
import Layout from '@layouts/Layout.astro';
import HomeHeader from '@components/HomeHeader.astro';
import HeroSlideshow from '@components/HeroSlideshow.astro';
import LogoIntro from '@components/LogoIntro.astro';
import Gallery from '@components/Gallery.astro';
import Footer from '@components/Footer.astro';
import { PAGES_SEO } from '@/consts';
import { getFeaturedTrabajos, resolveVideo } from '@lib/trabajos';

const seo = PAGES_SEO.home;

// Poster del primer slide del hero: preload con fetchpriority=high.
// El browser arranca a bajarlo en paralelo a la intro del logo, así cuando
// el hero aparece el poster ya está en cache → mejor LCP.
const featured = await getFeaturedTrabajos();
const firstPoster = featured.length > 0 ? resolveVideo(featured[0].data).poster : null;
---

<Layout title={seo.title} description={seo.description} bodyClass="intro-active">
  {
    firstPoster && (
      <Fragment slot="head">
        <link rel="preload" as="image" href={firstPoster} fetchpriority="high" />
      </Fragment>
    )
  }
  <LogoIntro />
  <HomeHeader />
  <HeroSlideshow />

  <section class="home-gallery-wrap">
    <header class="home-gallery-head">
      <span class="section-kicker">Nuestros trabajos</span>
      <h2 class="section-title">Lo último de Code</h2>
      <p class="section-sub">
        Una selección de los proyectos más recientes — aftermovies, comerciales, videoclips
        y documentales producidos en Uruguay y la región.
      </p>
    </header>
    <Gallery filter="all" />
  </section>

  <Footer />
</Layout>

<style is:global>
  body.intro-active { overflow: hidden; }

  .home-gallery-wrap {
    position: relative;
    z-index: 2;
    background: var(--bg);
  }

  .home-gallery-head {
    text-align: center;
    padding: 60px 5vw 28px;
  }

  .home-gallery-head .section-title {
    font-family: var(--ff-display);
    font-size: clamp(44px, 6.4vw, 92px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: var(--black);
  }

  .home-gallery-head .section-sub {
    max-width: 560px;
    margin: 14px auto 0;
    font-size: clamp(14px, 1.15vw, 17px);
    color: var(--black);
    opacity: 0.7;
    line-height: 1.5;
  }
</style>

<script>
  /**
   * Boot del intro: anima el logo, espera, y emite 'codestudio:intro-done'
   * que el HeroSlideshow escucha para arrancar.
   */
  (function () {
    const intro = document.getElementById('logoIntro');
    const introLogo = document.getElementById('introLogo');
    const hero = document.querySelector('.hero');
    let introDone = false;

    function finishIntro() {
      if (introDone) return;
      introDone = true;
      if (hero) hero.classList.add('ready');
      if (intro) intro.classList.add('done');
      document.body.classList.remove('intro-active');
      document.dispatchEvent(new CustomEvent('codestudio:intro-done'));
      setTimeout(() => {
        if (intro && intro.parentNode) intro.parentNode.removeChild(intro);
      }, 800);
    }

    function triggerReveal() {
      if (intro) intro.classList.add('reveal');
      setTimeout(finishIntro, 1450);
    }

    (async () => {
      if (introLogo && 'decode' in introLogo) {
        try { await (introLogo as HTMLImageElement).decode(); } catch (e) {}
      }
      requestAnimationFrame(() => requestAnimationFrame(triggerReveal));
    })();
  })();
</script>
