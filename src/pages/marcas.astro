---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PageHead from '@components/PageHead.astro';
import Gallery from '@components/Gallery.astro';
import { PAGES_SEO } from '@/consts';
import { getWorksByCategory } from '@/data/works';

const seo = PAGES_SEO.marcas;
const works = getWorksByCategory('Marcas');
---

<Layout title={seo.title} description={seo.description}>
  <Header current="/marcas" />
  <main>
    <PageHead title="Marcas" count={works.length} />
    <Gallery filter="Marcas" />
  </main>
  <Footer />
</Layout>
