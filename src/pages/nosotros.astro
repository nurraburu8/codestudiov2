</style>

<script>
  /**
   * Scroll-driven animation de las keywords + intersection observers para reveals.
   * Migrado desde legacy/nosotros.html.
   */
  (function () {
    'use strict';

    const kwWrap = document.getElementById('kwWrap');
    if (!kwWrap) return;
    const kwItems = document.querySelectorAll<HTMLElement>('.kw');
    const kwLogo = document.getElementById('kwLogo');
    const kwCta = document.getElementById('kwCta');
    const logoMark = document.getElementById('logoMark');
    let logoDanced = false;
    let revealReady = false;
    setTimeout(() => {
      revealReady = true;
      updateKw();
    }, 1400);

    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
    const clamp01 = (v: number) => Math.max(0, Math.min(1, v));

    function updateKw() {
      const rect = kwWrap!.getBoundingClientRect();
      const range = kwWrap!.offsetHeight - window.innerHeight;
      if (range <= 0) return;
      const vh = window.innerHeight;
      const scrolled = Math.max(0, -rect.top);
      const p = scrolled / range;
      const pre = clamp01((vh - rect.top) / (vh * 0.55));

      const TIMES = [
        { start: -0.05, dur: 0.2 },
        { start: 0.1, dur: 0.22 },
        { start: 0.28, dur: 0.22 },
        { start: 0.46, dur: 0.22 },
      ];

      kwItems.forEach((kw, i) => {
        const t = TIMES[i]!;
        const raw = clamp01((p - t.start) / t.dur);
        let ease = easeOut(raw);

        if (i === 0) ease = Math.max(ease, pre);
        else if (i === 1) ease = Math.max(ease, pre * 0.32);

        if (!revealReady && (i === 0 || i === 1)) ease = 0;

        const isR = i % 2 === 1;
        const fromX = isR ? 38 : -16;
        kw.style.transform = 'translateX(' + fromX * (1 - ease) + 'vw)';
        kw.style.opacity = String(ease);

        const sub = kw.querySelector<HTMLElement>('.kw-sub');
        if (sub) sub.style.opacity = String(clamp01((raw - 0.4) / 0.45));
      });

      const logoStart = 0.62;
      const logoRaw = clamp01((p - logoStart) / 0.14);
      const logoEase = easeOut(logoRaw);
      if (kwLogo) {
        kwLogo.style.opacity = String(logoEase);
        kwLogo.style.transform =
          'translateY(' + 20 * (1 - logoEase) + 'px) scale(' + (0.88 + logoEase * 0.12) + ')';
      }

      if (logoEase >= 0.95 && !logoDanced) {
        logoDanced = true;
        setTimeout(startDance, 250);
      }

      const ctaStart = 0.82;
      const ctaRaw = clamp01((p - ctaStart) / 0.14);
      if (kwCta) kwCta.style.opacity = String(easeOut(ctaRaw));
    }

    function startDance() {
      if (!logoMark) return;
      logoMark.classList.add('dancing');
      logoMark.addEventListener(
        'animationend',
        () => {
          logoMark.classList.remove('dancing');
          logoMark.classList.add('spinning');
        },
        { once: true }
      );
    }

    function setKwH() {
      kwWrap!.style.height = window.innerHeight * 1.5 + 'px';
    }

    setKwH();
    updateKw();
    window.addEventListener('resize', () => {
      setKwH();
      updateKw();
    });

    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => {
            updateKw();
            ticking = false;
          });
        }
      },
      { passive: true }
    );

    // ── Intersection reveals ───────────────────────
    const revealObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('vis');
            revealObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.18 }
    );

    document.querySelectorAll('.reveal').forEach((el) => revealObs.observe(el));
  })();
</script>
