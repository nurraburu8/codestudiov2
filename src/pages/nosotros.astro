---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { PAGES_SEO } from '@/consts';

const seo = PAGES_SEO.nosotros;

const brandsTop = [
  { src: '/logos/logo-vertical-negativo.png', alt: 'Gobierno de Canelones' },
  { src: '/logos/mercado libre.png', alt: 'Mercado Libre' },
  { src: '/logos/cif.png', alt: 'CIF' },
  { src: '/logos/sedal.png', alt: 'Sedal' },
  { src: '/logos/vns.png', alt: 'Vans' },
  { src: '/logos/volvo.png', alt: 'Volvo' },
  { src: '/logos/itau.png', alt: 'Itaú' },
];

const brandsBottom = [
  { src: '/logos/monster-energy-seeklogo.png', alt: 'Monster Energy' },
  { src: '/logos/assist-card-seeklogo.png', alt: 'Assist Card' },
  { src: '/logos/foton.png', alt: 'Foton' },
  { src: '/logos/college.png', alt: 'College' },
  { src: '/logos/fito paez.png', alt: 'Fito Páez' },
  { src: '/logos/deicas.png', alt: 'Familia Deicas' },
  { src: '/logos/britos.png', alt: 'Britos Hnos' },
];

const team = [
  { name: 'Valentí Prieto', role: 'Co-fundador' },
  { name: 'Franco Lorenzi', role: 'Co-fundador' },
  { name: 'Santiago Mondo', role: 'Co-fundador' },
  { name: 'Mateo Rodríguez Murias', role: 'Co-fundador' },
];

const keywords = [
  { label: 'Elegancia', sub: 'Distinción visual en cada proyecto', style: 'plain' },
  { label: 'Dinamismo', sub: 'Movimiento y evolución constante', style: 'outline-light' },
  { label: 'Cercanía', sub: 'Conexiones genuinas con tu audiencia', style: 'accent' },
  { label: 'Autenticidad', sub: 'La verdadera esencia de cada marca', style: 'outline-dark' },
];

const pillars = [
  {
    n: '01',
    name: 'Historia',
    text: 'Todo proyecto tiene algo que decir. Antes de filmar, entendemos qué es ese algo — cuál es la historia detrás de la marca, del artista, del momento. Ese es nuestro punto de partida.',
  },
  {
    n: '02',
    name: 'Estética',
    text: 'La imagen no es decoración. Es el lenguaje con el que la historia se comunica. Cada decisión visual — el plano, la luz, el ritmo — está al servicio de lo que se quiere contar.',
  },
  {
    n: '03',
    name: 'Ejecución',
    text: 'Una buena idea sin una buena producción no llega. Nos encargamos del proceso completo — concepto, rodaje y post — para que la historia llegue como tiene que llegar.',
  },
];
---

<Layout title={seo.title} description={seo.description} bodyClass="nosotros-page">
  <Header current="/nosotros" light={true} />

  <!-- INTRO -->
  <section class="intro">
    <p class="intro-tag">Productora audiovisual — Uruguay</p>
    <h1 class="intro-t">Nuestra<br />esencia</h1>
    <div class="intro-line"></div>
  </section>

  <!-- KEYWORDS scroll-driven -->
  <div class="kw-wrap" id="kwWrap">
    <div class="kw-sticky">
      <div class="kw-list" id="kwList">
        {
          keywords.map((kw, i) => (
            <div class="kw" data-kw={i}>
              <span
                class:list={[
                  'kw-t',
                  {
                    'kw-ol': kw.style === 'outline-light',
                    'kw-ac': kw.style === 'accent',
                    'kw-wol': kw.style === 'outline-dark',
                  },
                ]}
              >
                {kw.label}
              </span>
              <span class="kw-sub">{kw.sub}</span>
            </div>
          ))
        }
      </div>

      <div class="kw-logo" id="kwLogo">
        <div class="logo-row">
          <img class="logo-bk" id="logoMark" src="/logo2.png" alt="" />
          <img class="logo-tx" src="/codestudio2.png" alt="Code Studio" />
        </div>
        <p class="logo-tagline">For those who create <em>endlessly</em></p>
      </div>

      <div class="kw-cta" id="kwCta">
        <a href="/">Ver nuestro trabajo <span>→</span></a>
      </div>
    </div>
  </div>

  <!-- MANIFIESTO -->
  <section class="manifesto reveal" id="manifestoSection">
    <span class="manifesto-tag">Manifiesto</span>
    <h2 class="manifesto-lead">
      Code Studio es una productora audiovisual que trabaja
      <span class="accent">desde la historia.</span>
    </h2>
    <p>
      No arrancamos por el formato ni por la estética. Arrancamos por lo que hay que contar, para
      quién y por qué importa. Después viene la cámara.
    </p>
    <p>
      Trabajamos con marcas y artistas que entienden que una pieza audiovisual no es solo lo que se
      ve — es lo que queda.
    </p>
  </section>

  <!-- 3 PILARES -->
  <section class="pillars reveal" id="pillarsSection">
    {
      pillars.map((p) => (
        <div class="pillar">
          <div class="pillar-num">{p.n}</div>
          <div class="pillar-name">{p.name}</div>
          <p class="pillar-text">{p.text}</p>
        </div>
      ))
    }
  </section>

  <!-- VOICE -->
  <section class="voice reveal" id="voiceSection">
    <p class="voice-head">Tono de marca — Cómo habla Code</p>
    <h2 class="voice-lead">
      Code Studio habla directo. Sin relleno, sin frases motivacionales, sin
      <em>"pasión", "creatividad" o "soluciones integrales".</em>
    </h2>
    <p class="voice-intro">
      Cuando escribe, dice algo concreto. No se explica de más. No convence — muestra. El tono es
      seguro sin ser arrogante. Cercano sin ser informal. Siempre hay una idea detrás de cada
      frase.
    </p>

    <div class="voice-compare">
      <div class="voice-row no">
        <div class="voice-row-label">Lo que NO dice Code</div>
        <p class="voice-quote">
          "Somos un equipo apasionado que lleva tu marca al siguiente nivel."
        </p>
      </div>
      <div class="voice-row yes">
        <div class="voice-row-label">Lo que SÍ dice Code</div>
        <p class="voice-quote">"Cada proyecto esconde una historia. Juntos la hacemos real."</p>
      </div>
    </div>
  </section>

  <!-- MARCAS MARQUEE -->
  <section class="brands reveal" id="brandsSection">
    <header class="brands-head">
      <p class="brands-tag">Confiaron en nosotros</p>
      <h2 class="brands-title">Marcas que ya están en cancha</h2>
    </header>

    <div class="marquee">
      <div class="marquee-track">
        {
          brandsTop.map((b) => (
            <div class="marquee-item">
              <img src={b.src} alt={b.alt} loading="lazy" />
            </div>
          ))
        }
        {
          brandsTop.map((b) => (
            <div class="marquee-item" aria-hidden="true">
              <img src={b.src} alt="" loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>

    <div class="marquee reverse">
      <div class="marquee-track">
        {
          brandsBottom.map((b) => (
            <div class="marquee-item">
              <img src={b.src} alt={b.alt} loading="lazy" />
            </div>
          ))
        }
        {
          brandsBottom.map((b) => (
            <div class="marquee-item" aria-hidden="true">
              <img src={b.src} alt="" loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SLOGAN -->
  <section class="slogan reveal" id="sloganSection">
    <span class="slogan-line">Nacimos de una conexión real.</span>
    <span class="slogan-line">Pensamos para conectar.</span>
    <span class="slogan-tag">For those who create <em>endlessly</em></span>
  </section>

  <!-- TEAM -->
  <section class="team reveal" id="teamSection">
    <h2 class="team-head">El equipo</h2>
    <div class="team-grid">
      {
        team.map((m) => (
          <div class="team-card">
            <div class="tc-placeholder">
              <svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <path
                  d="M6 34 L6 14 C6 9.6 9.6 6 14 6 L34 6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                />
                <path
                  d="M34 6 L34 26 C34 30.4 30.4 34 26 34 L6 34"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                />
              </svg>
            </div>
            <div class="tc-name">
              {m.name}
              <span class="tc-role">{m.role}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* Tema MILK (fondo blanco) */
  body.nosotros-page {
    background: var(--milk);
    color: var(--black);
  }
  body.nosotros-page::after {
    opacity: 0.012;
  }
</style>

<style>
  /* ── INTRO ────────────────────────────────────── */
  .intro {
    position: relative;
    z-index: 1;
    min-height: 62vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(100px, 15vh, 160px) 5vw 40px;
  }

  .intro-tag {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: clamp(10px, 1vw, 12px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(20px);
    animation: fi 0.8s ease 0.3s forwards;
  }

  .intro-tag::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  .intro-t {
    font-family: var(--ff-display);
    font-size: clamp(56px, 11vw, 150px);
    line-height: 0.88;
    color: var(--black);
    opacity: 0;
    transform: translateY(30px);
    animation: fi 0.9s ease 0.5s forwards;
  }

  .intro-line {
    width: 2px;
    height: 56px;
    background: var(--light);
    margin-top: 48px;
    opacity: 0;
    animation: fi 0.6s ease 1.1s forwards;
  }

  @keyframes fi {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ── KEYWORDS SCROLL ─────────────────────────── */
  .kw-wrap {
    position: relative;
    z-index: 2;
  }

  .kw-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 18vh 7vw 4vh;
  }

  .kw-list {
    display: flex;
    flex-direction: column;
    gap: 1vh;
  }

  .kw {
    opacity: 0;
    transition: opacity 0.55s ease, transform 0.55s ease;
    will-change: transform, opacity;
  }

  .kw:nth-child(odd) { text-align: left; }
  .kw:nth-child(even) { text-align: right; }

  .kw-t {
    font-family: var(--ff-display);
    font-size: clamp(38px, 9vw, 110px);
    line-height: 0.9;
    display: block;
    color: var(--black);
  }

  .kw-ol {
    color: transparent;
    -webkit-text-stroke: 2px var(--light);
  }

  .kw-ac { color: var(--light); }

  .kw-wol {
    color: transparent;
    -webkit-text-stroke: 2px var(--black);
  }

  .kw-sub {
    display: block;
    font-size: clamp(11px, 1.1vw, 14px);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--black);
    opacity: 0;
    margin-top: 8px;
  }

  /* ── LOGO REVEAL ─────────────────────────────── */
  .kw-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding-top: 6vh;
    opacity: 0;
    will-change: transform, opacity;
    pointer-events: none;
  }

  .logo-row {
    display: flex;
    align-items: center;
    gap: clamp(8px, 1vw, 14px);
    position: relative;
  }

  .logo-bk {
    height: clamp(36px, 4.5vw, 52px);
    position: relative;
    z-index: 2;
    filter: brightness(0);
  }

  .logo-tx {
    height: clamp(22px, 2.8vw, 34px);
    filter: brightness(0);
  }

  .logo-tagline {
    font-size: clamp(11px, 1vw, 14px);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--black);
    opacity: 0.65;
  }

  .logo-tagline em {
    font-style: normal;
    font-size: clamp(14px, 1.5vw, 20px);
    letter-spacing: 0.12em;
    color: var(--light);
    font-weight: 600;
    opacity: 1;
  }

  .logo-bk.dancing {
    animation: bkDance 3s cubic-bezier(0.42, 0, 0.32, 1) forwards;
  }

  @keyframes bkDance {
    0% { transform: translateX(0); filter: brightness(0); }
    30% {
      transform: translateX(clamp(110px, 16vw, 230px));
      filter: brightness(0) drop-shadow(0 0 14px var(--light)) drop-shadow(-22px 0 12px rgba(253, 117, 43, 0.5));
    }
    62% {
      transform: translateX(clamp(-50px, -7vw, -90px));
      filter: brightness(0) drop-shadow(0 0 12px var(--light)) drop-shadow(22px 0 10px rgba(253, 117, 43, 0.42));
    }
    100% { transform: translateX(clamp(8px, 1vw, 16px)); filter: brightness(0); }
  }

  .logo-bk.spinning {
    animation: bkSpin 10s linear infinite;
    filter: brightness(0);
  }

  @keyframes bkSpin {
    from { transform: translateX(clamp(8px, 1vw, 16px)) rotate(0deg); }
    to { transform: translateX(clamp(8px, 1vw, 16px)) rotate(360deg); }
  }

  /* CTA */
  .kw-cta {
    text-align: center;
    padding-top: 4vh;
    opacity: 0;
    will-change: opacity;
    position: relative;
    z-index: 10;
  }

  .kw-cta a {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    min-height: 52px;
    box-sizing: border-box;
    font-family: var(--ff-display);
    font-size: clamp(14px, 1.2vw, 17px);
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--light);
    padding: 0 32px;
    line-height: 1;
    border: 1.5px solid var(--light);
    border-radius: 0;
    background: transparent;
    cursor: pointer;
    pointer-events: auto;
    transition: background 0.3s, color 0.3s, gap 0.35s var(--ease-out);
  }

  .kw-cta a:hover {
    background: var(--light);
    color: var(--black);
    gap: 18px;
  }

  .kw-cta a span {
    display: inline-block;
    transition: transform 0.35s var(--ease-out);
  }

  .kw-cta a:hover span { transform: translateX(4px); }

  /* ── REVEAL helper ──────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal.vis {
    opacity: 1;
    transform: none;
  }

  /* ── MANIFIESTO ─────────────────────────────── */
  .manifesto {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(80px, 12vh, 140px) 5vw clamp(40px, 6vh, 80px);
    text-align: center;
  }

  .manifesto-tag {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    margin-bottom: 32px;
  }

  .manifesto-tag::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  .manifesto-lead {
    font-family: var(--ff-display);
    font-size: clamp(26px, 3.6vw, 46px);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 42px;
    font-weight: 500;
  }

  .manifesto-lead .accent { color: var(--light); }

  .manifesto p {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.7;
    color: var(--black);
    opacity: 0.72;
    margin: 0 auto 22px;
    max-width: 640px;
  }

  .manifesto p:last-child { margin-bottom: 0; }

  /* ── PILARES ────────────────────────────────── */
  .pillars {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(60px, 9vh, 100px) 5vw clamp(80px, 12vh, 140px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(40px, 5vw, 80px);
  }

  .pillar-num {
    font-family: var(--ff-display);
    font-size: clamp(48px, 5.5vw, 82px);
    line-height: 1;
    color: var(--light);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
  }

  .pillar-name {
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--black);
    font-weight: 600;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1.5px solid var(--black);
  }

  .pillar-text {
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.65;
    color: var(--black);
    opacity: 0.75;
  }

  /* ── VOICE ──────────────────────────────────── */
  .voice {
    position: relative;
    z-index: 1;
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(60px, 9vh, 100px) 5vw clamp(80px, 12vh, 140px);
  }

  .voice-head {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    margin-bottom: 28px;
  }

  .voice-head::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  .voice-lead {
    font-family: var(--ff-display);
    font-size: clamp(22px, 2.8vw, 38px);
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--black);
    margin-bottom: 36px;
    max-width: 760px;
    font-weight: 500;
  }

  .voice-lead em {
    font-style: normal;
    color: var(--light);
    font-weight: 600;
  }

  .voice-intro {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.7;
    color: var(--black);
    opacity: 0.72;
    max-width: 680px;
    margin-bottom: 64px;
  }

  .voice-compare {
    display: grid;
    gap: 36px;
    max-width: 820px;
  }

  .voice-row {
    padding-top: 28px;
    border-top: 1px solid rgba(0, 0, 0, 0.15);
  }

  .voice-row-label {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .voice-row.no .voice-row-label { color: rgba(0, 0, 0, 0.45); }

  .voice-row.no .voice-row-label::before {
    content: '×';
    font-size: 18px;
    font-weight: 400;
  }

  .voice-row.no .voice-quote {
    font-family: var(--ff-display);
    font-size: clamp(20px, 2.2vw, 30px);
    line-height: 1.3;
    color: rgba(0, 0, 0, 0.45);
    font-style: italic;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(0, 0, 0, 0.35);
  }

  .voice-row.yes .voice-row-label { color: var(--light); }

  .voice-row.yes .voice-row-label::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--light);
  }

  .voice-row.yes .voice-quote {
    font-family: var(--ff-display);
    font-size: clamp(24px, 2.8vw, 38px);
    line-height: 1.25;
    color: var(--black);
    font-weight: 500;
  }

  /* ── BRANDS MARQUEE ─────────────────────────── */
  .brands {
    position: relative;
    z-index: 1;
    background: var(--black);
    color: var(--milk);
    padding: clamp(80px, 12vh, 130px) 0;
    overflow: hidden;
  }

  .brands-head {
    text-align: center;
    padding: 0 5vw;
    margin-bottom: clamp(48px, 7vh, 80px);
  }

  .brands-tag {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    font-weight: 500;
    margin-bottom: 22px;
  }

  .brands-tag::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
  }

  .brands-title {
    font-family: var(--ff-display);
    font-size: clamp(32px, 4.5vw, 64px);
    line-height: 1.1;
    color: var(--milk);
    letter-spacing: -0.01em;
    font-weight: 500;
  }

  .marquee {
    position: relative;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 8%,
      #000 92%,
      transparent 100%
    );
    mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }

  .marquee + .marquee { margin-top: clamp(20px, 3vh, 36px); }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marqueeL 48s linear infinite;
  }

  .marquee.reverse .marquee-track { animation: marqueeR 56s linear infinite; }

  @keyframes marqueeL {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @keyframes marqueeR {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 clamp(32px, 4.5vw, 64px);
    height: clamp(56px, 8vh, 80px);
  }

  .marquee-item img {
    height: 100%;
