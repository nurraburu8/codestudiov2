---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { PAGES_SEO } from '@/consts';

const seo = PAGES_SEO.nosotros;

const brandsTop = [
  { src: '/logos/logo-vertical-negativo.png', alt: 'Gobierno de Canelones' },
  { src: '/logos/mercado-libre.png', alt: 'Mercado Libre' },
  { src: '/logos/cif.png', alt: 'CIF' },
  { src: '/logos/sedal.png', alt: 'Sedal' },
  { src: '/logos/vns.png', alt: 'Vans' },
  { src: '/logos/volvo.png', alt: 'Volvo' },
  { src: '/logos/itau.png', alt: 'Itaú' },
];

const brandsBottom = [
  { src: '/logos/monster-energy-seeklogo.png', alt: 'Monster Energy' },
  { src: '/logos/assist-card-seeklogo.png', alt: 'Assist Card' },
  { src: '/logos/foton.png', alt: 'Foton' },
  { src: '/logos/college.png', alt: 'College' },
  { src: '/logos/fito-paez.png', alt: 'Fito Páez' },
  { src: '/logos/deicas.png', alt: 'Familia Deicas' },
  { src: '/logos/britos.png', alt: 'Britos Hnos' },
];

const team = [
  { name: 'Valentí Prieto', role: 'Co-fundador' },
  { name: 'Franco Lorenzi', role: 'Co-fundador' },
  { name: 'Santiago Mondo', role: 'Co-fundador' },
  { name: 'Mateo Rodríguez Murias', role: 'Co-fundador' },
];

const pillars = [
  {
    name: 'Historia',
    text: 'Todo proyecto tiene algo que decir. Antes de filmar, entendemos qué es ese algo — cuál es la historia detrás de la marca, del artista, del momento. Ese es nuestro punto de partida.',
  },
  {
    name: 'Estética',
    text: 'La imagen no es decoración. Es el lenguaje con el que la historia se comunica. Cada decisión visual — el plano, la luz, el ritmo — está al servicio de lo que se quiere contar.',
  },
  {
    name: 'Ejecución',
    text: 'Una buena idea sin una buena producción no llega. Nos encargamos del proceso completo — concepto, rodaje y post — para que la historia llegue como tiene que llegar.',
  },
];

const workingPhotos = [
  { label: 'Foto principal — rodaje', hint: 'Sugerido: 1600 × 1200px (4:3)' },
  { label: 'Behind the scenes', hint: '1200 × 900px' },
  { label: 'Locación / equipo', hint: '1200 × 900px' },
];
---

<Layout title={seo.title} description={seo.description} bodyClass="nosotros-page">
  <Header current="/nosotros" />

  <!-- INTRO -->
  <section class="intro">
    <p class="intro-tag">Productora audiovisual — Uruguay</p>
    <h1 class="intro-t">Nuestra<br />esencia</h1>
    <div class="intro-divider" aria-hidden="true"></div>
  </section>

  <!-- MANIFIESTO -->
  <section class="manifesto reveal" id="manifestoSection">
    <span class="manifesto-tag">Manifiesto</span>
    <h2 class="manifesto-lead">
      Code Studio es una productora audiovisual que trabaja
      <span class="accent">desde la historia.</span>
    </h2>
    <p>
      No arrancamos por el formato ni por la estética. Arrancamos por lo que hay que contar, para
      quién y por qué importa. Después viene la cámara.
    </p>
    <p>
      Trabajamos con marcas y artistas que entienden que una pieza audiovisual no es solo lo que se
      ve — es lo que queda.
    </p>
  </section>

  <!-- 2. PILARES (sin números, nombres grandes) -->
  <section class="pillars reveal" id="pillarsSection">
    {
      pillars.map((p) => (
        <div class="pillar">
          <h3 class="pillar-name">{p.name}</h3>
          <p class="pillar-text">{p.text}</p>
        </div>
      ))
    }
  </section>

  <!-- 3. EQUIPO (foto + nombre de cada uno) -->
  <section class="team reveal" id="teamSection">
    <h2 class="team-head">El equipo</h2>
    <div class="team-grid">
      {
        team.map((m) => (
          <div class="team-card">
            <div class="tc-placeholder">
              <svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <path
                  d="M6 34 L6 14 C6 9.6 9.6 6 14 6 L34 6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                />
                <path
                  d="M34 6 L34 26 C34 30.4 30.4 34 26 34 L6 34"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                />
              </svg>
            </div>
            <div class="tc-name">
              {m.name}
              <span class="tc-role">{m.role}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 4. EQUIPO EN ACCIÓN (fotos del equipo trabajando) -->
  <section class="team-action reveal" id="teamActionSection">
    <p class="team-action-head">El equipo en acción</p>
    <div class="team-action-grid">
      {
        workingPhotos.map((ph) => (
          <div class="photo-slot">
            <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
              <rect x="6" y="11" width="28" height="22" />
              <circle cx="20" cy="22" r="6" />
              <rect x="15" y="7" width="10" height="4" />
            </svg>
            <span class="photo-label">{ph.label}</span>
            <span class="photo-hint">{ph.hint}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 5. SLOGAN -->
  <section class="slogan reveal" id="sloganSection">
    <span class="slogan-line">Nacimos de una conexión real.</span>
    <span class="slogan-line">Pensamos para conectar.</span>
  </section>

  <!-- 6. MARCAS MARQUEE -->
  <section class="brands reveal" id="brandsSection">
    <header class="brands-head">
      <h2 class="brands-title">Marcas que confiaron en nosotros</h2>
    </header>

    <div class="marquee">
      <div class="marquee-track">
        {
          brandsTop.map((b) => (
            <div class="marquee-item">
              <picture>
                <source srcset={b.src.replace(/\.png$/, '.webp')} type="image/webp" />
                <img src={b.src} alt={b.alt} loading="eager" decoding="async" />
              </picture>
            </div>
          ))
        }
        {
          brandsTop.map((b) => (
            <div class="marquee-item" aria-hidden="true">
              <picture>
                <source srcset={b.src.replace(/\.png$/, '.webp')} type="image/webp" />
                <img src={b.src} alt="" loading="eager" decoding="async" />
              </picture>
            </div>
          ))
        }
      </div>
    </div>

    <div class="marquee reverse">
      <div class="marquee-track">
        {
          brandsBottom.map((b) => (
            <div class="marquee-item">
              <picture>
                <source srcset={b.src.replace(/\.png$/, '.webp')} type="image/webp" />
                <img src={b.src} alt={b.alt} loading="eager" decoding="async" />
              </picture>
            </div>
          ))
        }
        {
          brandsBottom.map((b) => (
            <div class="marquee-item" aria-hidden="true">
              <picture>
                <source srcset={b.src.replace(/\.png$/, '.webp')} type="image/webp" />
                <img src={b.src} alt="" loading="eager" decoding="async" />
              </picture>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* Grain extra sutil en esta página (más texto/contenido editorial). */
  body.nosotros-page::after {
    opacity: 0.012;
  }
</style>

<style>
  /* ── INTRO ────────────────────────────────────── */
  .intro {
    position: relative;
    z-index: 1;
    min-height: 62vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(100px, 15vh, 160px) 5vw 40px;
  }

  .intro-tag {
    display: inline-block;
    font-size: clamp(10px, 1vw, 12px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk */
    color: var(--black);
    font-weight: 500;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(20px);
    animation: fi 0.55s ease 0s forwards;
  }

  .intro-t {
    font-family: var(--ff-display);
    font-size: clamp(56px, 11vw, 150px);
    line-height: 0.88;
    color: var(--black);
    opacity: 0;
    transform: translateY(20px);
    animation: fi 0.65s ease 0.08s forwards;
  }

  /* Línea sutil de separación tras el título — solo seccionar, sin protagonismo. */
  .intro-divider {
    width: clamp(48px, 7vw, 88px);
    height: 1px;
    background: rgba(0, 0, 0, 0.18);
    margin: clamp(36px, 5vh, 56px) auto 0;
    opacity: 0;
    animation: fi 0.5s ease 0.28s forwards;
  }

  @keyframes fi {
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ── KEYWORDS SCROLL ─────────────────────────── */
  /* ── REVEAL helper ──────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal.vis {
    opacity: 1;
    transform: none;
  }

  /* ── MANIFIESTO ─────────────────────────────── */
  .manifesto {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(80px, 12vh, 140px) 5vw clamp(40px, 6vh, 80px);
    text-align: center;
  }

  .manifesto-tag {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk */
    color: var(--black);
    font-weight: 500;
    margin-bottom: 32px;
  }

  .manifesto-lead {
    font-family: var(--ff-display);
    font-size: clamp(26px, 3.6vw, 46px);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 42px;
    font-weight: 500;
  }

  .manifesto-lead .accent { color: var(--light); }

  .manifesto p {
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.7;
    color: var(--black);
    opacity: 0.72;
    margin: 0 auto 22px;
    max-width: 640px;
  }

  .manifesto p:last-child { margin-bottom: 0; }

  /* ── PILARES ────────────────────────────────── */
  .pillars {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(60px, 9vh, 100px) 5vw clamp(80px, 12vh, 140px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(40px, 5vw, 80px);
  }

  /* Nombre del pilar como título grande, Bebas/Space display. */
  .pillar-name {
    font-family: var(--ff-display);
    font-size: clamp(40px, 4.6vw, 68px);
    line-height: 1;
    color: var(--black);
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 22px;
  }

  .pillar-text {
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.65;
    color: var(--black);
    opacity: 0.78;
  }

  /* ── EQUIPO EN ACCIÓN (fotos del equipo trabajando) ── */
  .team-action {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5vw clamp(80px, 12vh, 140px);
  }

  .team-action-head {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    /* Negro para contraste WCAG sobre milk */
    color: var(--black);
    font-weight: 500;
    margin-bottom: 36px;
  }

  .team-action-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
    height: clamp(420px, 62vh, 640px);
  }

  .photo-slot {
    position: relative;
    background: rgba(0, 0, 0, 0.025);
    border: 1px dashed rgba(0, 0, 0, 0.28);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--black);
    transition: background 0.25s, border-color 0.25s, color 0.25s;
  }

  .photo-slot:first-child { grid-row: 1 / 3; }

  .photo-slot:hover {
    background: rgba(253, 117, 43, 0.06);
    border-color: var(--light);
    color: var(--light);
  }

  .photo-slot svg {
    width: 38px;
    height: 38px;
    opacity: 0.55;
    transition: opacity 0.25s;
  }

  .photo-slot:hover svg { opacity: 1; }

  .photo-label {
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .photo-hint {
    font-size: 11px;
    opacity: 0.55;
    font-weight: 400;
  }

  /* ── BRANDS MARQUEE ─────────────────────────── */
  .brands {
    position: relative;
    z-index: 1;
    background: var(--black);
    color: var(--milk);
    padding: clamp(80px, 12vh, 130px) 0;
    overflow: hidden;
  }

  .brands-head {
    text-align: center;
    padding: 0 5vw;
    margin-bottom: clamp(48px, 7vh, 80px);
  }

  .brands-title {
    font-family: var(--ff-display);
    font-size: clamp(32px, 4.5vw, 64px);
    line-height: 1.1;
    color: var(--milk);
    letter-spacing: -0.01em;
    font-weight: 500;
  }

  .marquee {
    position: relative;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 8%,
      #000 92%,
      transparent 100%
    );
    mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }

  .marquee + .marquee { margin-top: clamp(20px, 3vh, 36px); }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marqueeL 48s linear infinite;
  }

  .marquee.reverse .marquee-track { animation: marqueeR 56s linear infinite; }

  @keyframes marqueeL {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @keyframes marqueeR {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  /* Cajita fija para cada logo — width + height uniformes. La <img>
     se contiene adentro con object-fit, así marcas verticales y
     horizontales quedan al mismo "peso" visual. */
  .marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(150px, 16vw, 200px);
    height: clamp(70px, 9vh, 96px);
    padding: 0 clamp(16px, 2vw, 28px);
  }

  /* picture no tiene dimensiones propias — display:contents lo "desaparece"
     del árbol de layout y el img hereda el flex-item directamente. */
  .marquee-item picture { display: contents; }

  .marquee-item img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.78;
    transition: opacity 0.3s, transform 0.3s;
  }

  .marquee-item:hover img { opacity: 1; transform: scale(1.04); }

  .marquee:hover .marquee-track { animation-play-state: paused; }

  /* ── SLOGAN ─────────────────────────────────── */
  .slogan {
    position: relative;
    z-index: 1;
    padding: 100px 5vw 120px;
    text-align: center;
    overflow: hidden;
  }

  .slogan-line {
    display: block;
    font-family: var(--ff-display);
    font-size: clamp(28px, 5vw, 72px);
    line-height: 1.1;
    color: var(--black);
  }

  .slogan-line:nth-child(2) { color: var(--light); }

  /* ── TEAM ───────────────────────────────────── */
  .team {
    position: relative;
    z-index: 1;
    padding: 0 5vw 120px;
  }

  .team-head {
    font-family: var(--ff-display);
    font-size: clamp(28px, 3.5vw, 52px);
    text-align: center;
    margin-bottom: 48px;
    color: var(--black);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(12px, 1.5vw, 24px);
    max-width: 960px;
    margin: 0 auto;
  }

  .team-card {
    position: relative;
    border-radius: 0;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .tc-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--black);
  }

  .tc-placeholder svg {
    width: 40%;
    height: 40%;
    opacity: 0.18;
  }

  .tc-name {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 16px;
    font-size: clamp(11px, 1vw, 14px);
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--black);
  }

  .tc-role {
    display: block;
    font-size: 0.78em;
    /* Negro para contraste WCAG sobre card claro */
    color: var(--black);
    margin-top: 3px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── RESPONSIVE ─────────────────────────────── */
  @media (max-width: 820px) {
    .intro { min-height: 52vh; padding-top: clamp(90px, 13vh, 130px); }
    .pillars { grid-template-columns: 1fr; gap: 48px; }
    .pillar-name { font-size: clamp(36px, 9vw, 56px); }
    .team-action-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 1.4fr 1fr 1fr;
      height: auto;
      min-height: 580px;
    }
    .photo-slot:first-child { grid-row: auto; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .slogan-line { font-size: clamp(24px, 8vw, 48px); }
    .marquee-item {
      width: clamp(120px, 32vw, 160px);
      height: clamp(60px, 8vh, 78px);
    }
  }
</style>

<script>
  /** Intersection reveals para fade-in al entrar al viewport. */
  const revealObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('vis');
          revealObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.18 }
  );
  document.querySelectorAll('.reveal').forEach((el) => revealObs.observe(el));
</script>
