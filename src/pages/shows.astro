---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PageHead from '@components/PageHead.astro';
import Gallery from '@components/Gallery.astro';
import { PAGES_SEO } from '@/consts';
import { getTrabajosByCategory } from '@lib/trabajos';

const seo = PAGES_SEO.shows;
const works = await getTrabajosByCategory('Shows & Fiestas');
---

<Layout title={seo.title} description={seo.description}>
  <Header current="/shows" />
  <main>
    <PageHead title="Shows & Fiestas" count={works.length} />
    <Gallery filter="Shows & Fiestas" />
  </main>
  <Footer />
</Layout>
