---
/**
 * Layout base de todas las páginas.
 * Centraliza meta tags SEO, Open Graph, Twitter Cards, JSON-LD,
 * preconnect a fuentes, favicon y estilos globales.
 */
import { SITE, ORGANIZATION_SCHEMA, DEFAULT_OG_IMAGE } from '@/consts';
import '@styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Path relativo a public/ (ej: "/og/home.jpg") o URL absoluta */
  ogImage?: string;
  /** Path relativo del sitio para canonical (ej: "/contacto") */
  canonicalPath?: string;
  /** "website" (default) o "article" */
  ogType?: 'website' | 'article';
  /** Si true, agrega noindex/nofollow */
  noindex?: boolean;
  /** Schema JSON-LD adicional (además del Organization) */
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage = DEFAULT_OG_IMAGE,
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(canonicalPath, Astro.site ?? SITE.url).toString();
const ogImageURL = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, Astro.site ?? SITE.url).toString();
---

<!doctype html>
<html lang="es-UY">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- ── Primary Meta Tags ─────────────────────── -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- ── Open Graph / Facebook / WhatsApp ───────── -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.defaultLocale} />

    <!-- ── Twitter Cards ────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- ── Favicon set ────────────────────────────── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />

    <!-- ── Preconnect fuentes ─────────────────────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- ── Schema.org Organization (JSON-LD) ──────── -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(ORGANIZATION_SCHEMA)}
    />

    {
      jsonLd && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
      )
    }

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
