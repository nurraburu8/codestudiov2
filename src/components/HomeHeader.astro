---
/**
 * Header del home: layout split (logo izq, nav central, nav derecha).
 * Distinto al Header normal porque acompaña el slideshow del hero.
 */
import { SITE } from '@/consts';
---

<header class="home-header" id="homeHeader">
  <div class="header-left">
    <a href="/" class="logo" aria-label={`${SITE.name} - Inicio`}>
      <img src="/logo.png" alt={SITE.name} width="36" height="36" />
    </a>
  </div>
  <nav class="header-center" aria-label="Categorías">
    <a href="/shows">Shows & Fiestas</a>
    <a href="/marcas">Marcas</a>
    <a href="/eventos">Eventos</a>
  </nav>
  <nav class="header-right" aria-label="Más">
    <a href="/nosotros">Sobre nosotros</a>
    <a href="/contacto">Contacto</a>
  </nav>
  <button
    class="ham"
    id="homeHam"
    aria-label="Abrir menú"
    aria-expanded="false"
    aria-controls="homeMobMenu"
  >
    <span></span><span></span><span></span>
  </button>
</header>

<div class="mob-menu" id="homeMobMenu" aria-hidden="true">
  <a href="/">Inicio</a>
  <a href="/shows">Shows & Fiestas</a>
  <a href="/marcas">Marcas</a>
  <a href="/eventos">Eventos</a>
  <a href="/nosotros">Sobre nosotros</a>
  <a href="/contacto">Contacto</a>
</div>

<style>
  .home-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    padding: 14px 5vw;
    background: var(--black);
  }

  /* .scrolled mantiene los mismos estilos — header ya es negro siempre. */
  .home-header.scrolled { background: var(--black); }

  .header-left { flex: 1; }

  .logo img {
    height: clamp(40px, 4.5vw, 64px);
    width: auto;
    display: block;
    filter: brightness(0) invert(1);   /* logo blanco sobre header negro */
  }

  .header-center {
    flex: 1;
    display: flex;
    justify-content: center;
    gap: 32px;
  }

  .header-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    gap: 24px;
  }

  .header-center a,
  .header-right a {
    /* Padding vertical para hit area de 32px+ (WCAG tactile targets) */
    display: inline-block;
    padding: 10px 0;
    font-family: var(--ff-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--milk);
    transition: color 0.25s;
    position: relative;
  }

  .header-center a::after,
  .header-right a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--light);
    transition: width 0.3s var(--ease-out);
  }

  .header-center a:hover,
  .header-right a:hover { color: var(--light); }

  .header-center a:hover::after,
  .header-right a:hover::after { width: 100%; }

  /* ── Hamburger ──────────────────────────────────────── */
  .ham {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    /* Hit area 44x44 (WCAG tactile targets) */
    min-width: 44px;
    min-height: 44px;
    padding: 10px;
    background: none;
    border: none;
  }

  .ham span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--milk);
    transition: transform 0.3s, opacity 0.3s;
  }

  .ham.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .ham.open span:nth-child(2) { opacity: 0; }
  .ham.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Mobile menu ────────────────────────────────────── */
  .mob-menu {
    position: fixed;
    inset: 0;
    z-index: 299;
    background: var(--black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .mob-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mob-menu a {
    font-family: var(--ff-display);
    font-size: clamp(28px, 8vw, 48px);
    letter-spacing: 0.08em;
    color: var(--milk);
    transition: color 0.25s;
  }

  .mob-menu a:hover { color: var(--light); }

  /* ── Mobile layout ──────────────────────────────────── */
  @media (max-width: 820px) {
    .home-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 14px 5vw;
      gap: 0;
    }
    .header-left {
      flex: none;
      grid-column: 2;
      justify-self: center;
    }
    .logo img { height: clamp(48px, 14vw, 64px); }
    .header-center,
    .header-right { display: none !important; }
    .ham {
      display: flex;
      grid-column: 3;
      justify-self: end;
    }
  }
</style>

<script>
  /**
   * Scroll spy + toggle del menú mobile.
   */
  const header = document.getElementById('homeHeader');
  const ham = document.getElementById('homeHam');
  const mobMenu = document.getElementById('homeMobMenu');

  if (header) {
    window.addEventListener(
      'scroll',
      () => {
        header.classList.toggle('scrolled', window.scrollY > 50);
      },
      { passive: true }
    );
  }

  if (ham && mobMenu) {
    ham.addEventListener('click', () => {
      const isOpen = ham.classList.toggle('open');
      mobMenu.classList.toggle('open', isOpen);
      mobMenu.setAttribute('aria-hidden', String(!isOpen));
      ham.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    mobMenu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        ham.classList.remove('open');
        mobMenu.classList.remove('open');
        mobMenu.setAttribute('aria-hidden', 'true');
        ham.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobMenu.classList.contains('open')) {
        ham.click();
      }
    });
  }
</script>
