---
/**
 * Hero slideshow del home.
 * Lee los trabajos desde la colección y los renderiza como slides.
 */
import { getFeaturedTrabajos, resolveVideo } from '@lib/trabajos';

const slides = (await getFeaturedTrabajos()).map((w) => ({
  entry: w,
  ...resolveVideo(w.data),
}));
const slideMeta = slides.map((s) => ({
  id: s.entry.id,
  type: s.entry.data.type,
  client: s.entry.data.client,
}));
---

<section class="hero">
  <div
    class="slideshow"
    id="slideshow"
    role="link"
    aria-label="Ver detalle del trabajo destacado"
    tabindex="0"
  >
    {
      slides.map((s, i) => (
        <div class={`slide ${i === 0 ? 'active' : ''}`} data-id={s.entry.id}>
          <video
            muted
            loop
            playsinline
            preload={i === 0 ? 'auto' : 'none'}
            poster={s.poster}
          >
            <source src={s.src} type="video/mp4" />
          </video>
        </div>
      ))
    }
  </div>

  <div class="bottom">
    <a class="work-title" id="workTitleLink" href="#">
      <span class="type" id="workType"></span>
      <span class="client" id="workClient"></span>
    </a>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>
    <div class="bottom-row">
      <div class="slide-nav" id="slideNav">
        {
          slides.map((_, i) => (
            <button class={i === 0 ? 'active' : ''} data-index={i}>
              {i + 1}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script define:vars={{ worksData: slideMeta }}>
  (function () {
    const SLIDE_DURATION = 7000;

    const slides = Array.from(document.querySelectorAll('.slide'));
    const btns = Array.from(document.querySelectorAll('#slideNav button'));
    const titleType = document.getElementById('workType');
    const titleClient = document.getElementById('workClient');
    const titleLink = document.getElementById('workTitleLink');
    const progressFill = document.getElementById('progressFill');
    const slideshow = document.getElementById('slideshow');

    if (!slides.length || !titleType || !titleClient || !titleLink || !progressFill) return;

    let current = 0;
    let advanceTimer = null;
    let progressRAF = null;

    function getWork(id) {
      return worksData.find((w) => w.id === id) || { type: '', client: '', id };
    }

    function setSpans(el, text, startOffset) {
      el.innerHTML = '';
      if (!text) return;
      const words = String(text).split(' ');
      let i = startOffset || 0;
      words.forEach((word, wi) => {
        const wordSpan = document.createElement('span');
        wordSpan.className = 'word';
        for (const ch of word) {
          const s = document.createElement('span');
          s.className = 'char';
          s.textContent = ch;
          s.style.animationDelay = i * 28 + 'ms';
          wordSpan.appendChild(s);
          i++;
        }
        el.appendChild(wordSpan);
        if (wi < words.length - 1) {
          el.appendChild(document.createTextNode(' '));
          i++;
        }
      });
    }

    function renderTitle(work) {
      setSpans(titleType, work.type, 0);
      const offset = (work.type || '').length + 2;
      setSpans(titleClient, work.client || '', offset);
      titleLink.href = work.id ? `/work/${work.id}` : '#';
    }

    function animateProgress() {
      cancelAnimationFrame(progressRAF);
      const start = performance.now();
      const step = (now) => {
        const elapsed = now - start;
        const pct = Math.min(100, (elapsed / SLIDE_DURATION) * 100);
        progressFill.style.width = pct + '%';
        if (pct < 100) progressRAF = requestAnimationFrame(step);
      };
      progressRAF = requestAnimationFrame(step);
    }

    function ensureVideoLoaded(v) {
      if (!v) return;
      if (v.preload !== 'auto') {
        v.preload = 'auto';
        try { v.load(); } catch (e) {}
      }
    }

    function goTo(idx) {
      slides[current].classList.remove('active');
      btns[current].classList.remove('active');
      const prevVideo = slides[current].querySelector('video');
      if (prevVideo) prevVideo.pause();

      current = idx;
      const slide = slides[current];
      slide.classList.add('active');
      btns[current].classList.add('active');

      const id = slide.dataset.id;
      renderTitle(getWork(id));

      const v = slide.querySelector('video');
      if (v) {
        ensureVideoLoaded(v);
        try { v.currentTime = 0; } catch (e) {}
        const p = v.play();
        if (p && p.catch) p.catch(() => {});
      }

      // Prefetch del próximo slide para que la transición sea fluida.
      // Empieza a bufferear el siguiente video apenas el actual comienza
      // a reproducirse — así para cuando avance (en 7s) ya está listo.
      const nextSlide = slides[(current + 1) % slides.length];
      const nextVideo = nextSlide?.querySelector('video');
      if (nextVideo) ensureVideoLoaded(nextVideo);

      progressFill.style.width = '0%';
      animateProgress();

      clearTimeout(advanceTimer);
      advanceTimer = setTimeout(() => goTo((current + 1) % slides.length), SLIDE_DURATION);
    }

    btns.forEach((b) =>
      b.addEventListener('click', () => goTo(parseInt(b.dataset.index, 10)))
    );

    if (slideshow) {
      slideshow.addEventListener('click', () => {
        const href = titleLink.getAttribute('href');
        if (href && href !== '#') window.location.href = href;
      });
      slideshow.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          slideshow.click();
        }
      });
    }

    const firstVideo = slides[0].querySelector('video');
    if (firstVideo) {
      try { firstVideo.load(); } catch (e) {}
    }

    function startSlideshow() {
      const id = slides[0].dataset.id;
      renderTitle(getWork(id));
      const fv = slides[0].querySelector('video');
      if (fv) {
        ensureVideoLoaded(fv);
        const p = fv.play();
        if (p && p.catch) p.catch(() => {});
      }
      animateProgress();
      advanceTimer = setTimeout(() => goTo((current + 1) % slides.length), SLIDE_DURATION);
    }

    document.addEventListener('codestudio:intro-done', startSlideshow, { once: true });

    setTimeout(() => {
      if (!progressRAF) startSlideshow();
    }, 2500);
  })();
</script>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 0.85s var(--ease-out),
      transform 1s var(--ease-out);
  }

  :global(.hero.ready) {
    opacity: 1;
    transform: scale(1);
  }

  .slideshow {
    position: absolute;
    inset: 0;
    z-index: 1;
    cursor: pointer;
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.9s ease;
  }

  .slide.active { opacity: 1; }

  .slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slideshow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
    pointer-events: none;
    z-index: 2;
  }

  .bottom {
    position: absolute;
    bottom: 28px;
    left: 0;
    right: 0;
    z-index: 5;
    padding: 0 28px;
  }

  .work-title {
    font-size: clamp(40px, 7vw, 92px);
    line-height: 0.92;
    margin-bottom: 22px;
    max-width: 92%;
    display: block;
    color: var(--milk);
  }

  .work-title :global(.type),
  .work-title :global(.client) {
    display: block;
  }

  .work-title :global(.type) {
    display: inline-block;
    font-family: var(--ff-body);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(10px, 1vw, 13px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--light);
    margin-bottom: 1.4em;
  }

  .work-title :global(.client) {
    font-family: var(--ff-display);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding-left: 0.5em;
  }

  .work-title :global(.word) {
    display: inline-block;
    white-space: nowrap;
  }

  .work-title :global(.char) {
    display: inline-block;
    opacity: 0;
    transform: translateY(46px);
    filter: blur(12px);
    animation: charIn 0.85s cubic-bezier(0.2, 0.85, 0.2, 1) forwards;
  }

  @keyframes charIn {
    0% { opacity: 0; transform: translateY(46px); filter: blur(12px); }
    60% { filter: blur(0); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .progress-bar {
    width: 100%;
    max-width: 460px;
    height: 3px;
    background: rgba(255, 255, 255, 0.22);
    margin-bottom: 14px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--light);
    will-change: width;
  }

  .bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .slide-nav {
    display: flex;
    gap: 32px;
  }

  .slide-nav button {
    background: none;
    border: none;
    font-family: inherit;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--milk);
    opacity: 0.55;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s, opacity 0.2s, font-weight 0.2s;
  }

  .slide-nav button.active {
    color: var(--light);
    font-weight: 700;
    opacity: 1;
  }

  .slide-nav button:hover { opacity: 1; }

  @media (max-width: 820px) {
    .bottom { bottom: 28px; padding: 0 20px; }
    .work-title {
      font-size: clamp(28px, 8.8vw, 52px);
      margin-bottom: 16px;
      line-height: 0.95;
    }
    .work-title :global(.type) {
      font-size: clamp(10px, 2.6vw, 12px);
      letter-spacing: 0.28em;
      margin-bottom: 1.2em;
    }
    .work-title :global(.client) { padding-left: 0.3em; }
    .progress-bar { margin-bottom: 14px; }
    .bottom-row { flex-direction: column; align-items: flex-start; gap: 14px; }
    .slide-nav {
      gap: 22px;
      overflow-x: auto;
      scrollbar-width: none;
      width: 100%;
    }
    .slide-nav::-webkit-scrollbar { display: none; }
    .slide-nav button { font-size: 22px; flex: 0 0 auto; }
  }
</style>
