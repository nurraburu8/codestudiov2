---
/**
 * Header navegacional compartido entre páginas internas
 * (shows, marcas, eventos, nosotros, contacto).
 * El index tiene su propio header inline porque maneja el slideshow + intro.
 */
import { SITE } from '@/consts';

interface Props {
  /** Path actual para resaltar el link activo (ej: "/contacto") */
  current?: string;
  /** Si true, aplica tema claro (para páginas con fondo blanco como nosotros/contacto) */
  light?: boolean;
}

const { current = '', light = false } = Astro.props;

const links = [
  { href: '/shows', label: 'Shows & Fiestas' },
  { href: '/marcas', label: 'Marcas' },
  { href: '/eventos', label: 'Eventos' },
  { href: '/nosotros', label: 'Sobre nosotros' },
  { href: '/contacto', label: 'Contacto' },
];
---

<nav class:list={['nav', { 'nav-light': light }]} aria-label="Navegación principal">
  <a href="/" class="nav-b" aria-label={`${SITE.name} - Inicio`}>
    <img src="/logo.png" alt={SITE.name} width="36" height="36" />
  </a>

  <ul class="nav-l">
    {
      links.map((link) => (
        <li>
          <a href={link.href} class:list={[{ act: current === link.href }]}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <button class="ham" aria-label="Abrir menú" aria-expanded="false" aria-controls="mob-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mob-menu" id="mob-menu" aria-hidden="true">
  <a href="/">Inicio</a>
  {links.map((link) => <a href={link.href}>{link.label}</a>)}
</div>

<style>
  /* ── NAVBAR (migrado de legacy/css/nav.css) ─────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 5vw;
    background: var(--black);
    transition: transform 0.45s var(--ease-out);
  }

  /* .scrolled mantiene los mismos estilos que el default — ya está negro. */
  .nav.scrolled { background: var(--black); }

  .nav.hide { transform: translateY(-100%); }

  .nav-b { display: flex; align-items: center; }
  .nav-b img {
    height: 36px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .nav-l {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-l a {
    font-family: var(--ff-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--milk);
    opacity: 0.85;
    transition: color 0.25s, opacity 0.25s;
    position: relative;
  }

  .nav-l a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--light);
    transition: width 0.3s var(--ease-out);
  }

  .nav-l a:hover { opacity: 1; color: var(--light); }
  .nav-l a:hover::after { width: 100%; }
  .nav-l a.act { opacity: 1; color: var(--light); }
  .nav-l a.act::after { width: 100%; }

  /* ── Hamburger ──────────────────────────────────────── */
  .ham {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    z-index: 301;
    padding: 8px;
  }

  .ham span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--milk);
    transition: transform 0.3s, opacity 0.3s;
  }

  .ham.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .ham.open span:nth-child(2) { opacity: 0; }
  .ham.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Mobile menu fullscreen ─────────────────────────── */
  .mob-menu {
    position: fixed;
    inset: 0;
    z-index: 299;
    background: var(--black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .mob-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mob-menu a {
    font-family: var(--ff-display);
    font-size: clamp(28px, 8vw, 48px);
    letter-spacing: 0.08em;
    color: var(--milk);
    transition: color 0.25s;
  }

  .mob-menu a:hover { color: var(--light); }

  /* ── Mobile layout (logo centered, ham right) ───────── */
  @media (max-width: 820px) {
    .nav {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 14px 5vw;
    }
    .nav-b { grid-column: 2; justify-self: center; }
    .nav-b img { height: 32px; }
    .nav-l { display: none; }
    .ham { display: flex; grid-column: 3; justify-self: end; }
  }
</style>

<script>
  /**
   * Comportamiento del nav: scroll-spy, hide-on-scroll-down,
   * toggle del menú mobile.
   */
  const nav = document.querySelector('.nav');
  const ham = document.querySelector('.ham');
  const mobMenu = document.getElementById('mob-menu');

  if (nav && ham && mobMenu) {
    let lastScroll = 0;

    window.addEventListener(
      'scroll',
      () => {
        const y = window.scrollY;
        nav.classList.toggle('scrolled', y > 50);

        // Hide on scroll down, show on scroll up (después de 200px)
        if (y > 200) {
          nav.classList.toggle('hide', y > lastScroll);
        } else {
          nav.classList.remove('hide');
        }
        lastScroll = y;
      },
      { passive: true }
    );

    ham.addEventListener('click', () => {
      const isOpen = ham.classList.toggle('open');
      mobMenu.classList.toggle('open', isOpen);
      mobMenu.setAttribute('aria-hidden', String(!isOpen));
      ham.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    // Cerrar mob menu al click en cualquier link
    mobMenu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        ham.classList.remove('open');
        mobMenu.classList.remove('open');
        mobMenu.setAttribute('aria-hidden', 'true');
        ham.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }
</script>
