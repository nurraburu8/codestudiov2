---
import SocialIcons from '@components/SocialIcons.astro';

interface Props {
  /** Si true, oculta las redes en el footer (cuando la página ya las muestra en el body, ej: contacto). */
  hideSocials?: boolean;
}
const { hideSocials = false } = Astro.props;
---

<footer class="site-footer">
  <div class="fgr">
    <div class="fl">Code<i>.</i>Studio</div>
    <div class="fc">
      <img src="/logo.png" alt="" width="32" height="32" aria-hidden="true" />
    </div>
    {
      !hideSocials && (
        <div class="f-social">
          <SocialIcons />
        </div>
      )
    }
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    padding: 42px 5vw 30px;
    background: var(--black);
  }

  .fgr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .fl {
    font-family: var(--ff-display);
    font-size: 24px;
    letter-spacing: 0.1em;
    color: var(--milk);
    flex: 1;
  }

  .fl i {
    color: var(--light);
    font-style: normal;
  }

  .fc {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .fc img {
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  /* Redes — heredan currentColor del footer para integrarse al tema oscuro. */
  .f-social {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    color: var(--milk);
  }

  /* Compactar tamaño de los iconos dentro del footer (más chicos que en contacto). */
  .f-social :global(.socials) { gap: 10px; }
  .f-social :global(.socials a) {
    width: 38px;
    height: 38px;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .f-social :global(.socials svg) { width: 15px; height: 15px; }

  @media (max-width: 820px) {
    .site-footer { padding: 36px 5vw 28px; }
    .fgr { flex-direction: column; text-align: center; gap: 20px; }
    /* En mobile el wordmark "Code.Studio" duplica visualmente al logo — ocultarlo. */
    .fl { display: none; }
    .f-social { flex: none; justify-content: center; }
  }
</style>
