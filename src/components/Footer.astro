---
import SocialIcons from '@components/SocialIcons.astro';

interface Props {
  /** Si true, oculta las redes en el footer (cuando la página ya las muestra en el body, ej: contacto). */
  hideSocials?: boolean;
}
const { hideSocials = false } = Astro.props;
---

<footer class:list={['site-footer', { 'only-logo': hideSocials }]}>
  <div class="fgr">
    <div class="fc">
      <img src="/logo.png" alt="Code Studio" width="40" height="40" />
    </div>
    {
      !hideSocials && (
        <div class="f-social">
          <SocialIcons />
        </div>
      )
    }
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    padding: 36px 5vw 32px;
    background: var(--black);
  }

  /* Layout default (logo izq, redes der). Cuando solo hay logo, se centra. */
  .fgr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .site-footer.only-logo .fgr { justify-content: center; }

  .fc {
    display: flex;
    align-items: center;
  }

  .fc img {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity 0.25s;
  }

  .fc img:hover { opacity: 1; }

  /* Redes — heredan currentColor del footer para integrarse al tema oscuro. */
  .f-social {
    display: flex;
    align-items: center;
    color: var(--milk);
  }

  /* Iconos compactos dentro del footer (más chicos que la versión de contacto). */
  .f-social :global(.socials) { gap: 10px; }
  .f-social :global(.socials a) {
    width: 38px;
    height: 38px;
    border-color: rgba(255, 255, 255, 0.32);
  }
  .f-social :global(.socials svg) { width: 15px; height: 15px; }

  @media (max-width: 820px) {
    .site-footer { padding: 32px 5vw 28px; }
    .fgr { flex-direction: column; gap: 22px; }
    .fc img { height: 36px; }
  }
</style>
