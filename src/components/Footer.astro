---
import { SITE } from '@/consts';
---

<footer class="site-footer">
  <div class="fgr">
    <div class="fl">Code<i>.</i>Studio</div>
    <div class="fc">
      <img src="/logo.png" alt="" width="32" height="32" aria-hidden="true" />
      <span>{SITE.tagline}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    padding: 42px 5vw 30px;
    background: var(--black);
    border-top: 2px solid var(--light);
  }

  .fgr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .fl {
    font-family: var(--ff-display);
    font-size: 24px;
    letter-spacing: 0.1em;
    color: var(--milk);
  }

  .fl i {
    color: var(--light);
    font-style: normal;
  }

  .fc {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .fc img {
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  .fc span {
    font-size: 9px;
    letter-spacing: 0.22em;
    color: var(--mute);
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .site-footer { padding: 36px 5vw 28px; }
    .fgr { flex-direction: column; text-align: center; gap: 16px; }
    .fl { font-size: 22px; }
  }
</style>
