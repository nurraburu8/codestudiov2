# Code Studio — Variables de entorno
# Copiar este archivo como .env y completar con valores reales.
# NUNCA commitear el .env real al repo.

# ── Cloudinary (hosting de imagenes y videos) ──
PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Web3Forms (backend del formulario de contacto) ──
PUBLIC_WEB3FORMS_ACCESS_KEY=

# ── Email destinatario del formulario ──
PUBLIC_CONTACT_EMAIL=hola@codestudio.com.uy

# ── URL canonica del sitio (sin trailing slash) ──
PUBLIC_SITE_URL=https://codestudio.com.uy
